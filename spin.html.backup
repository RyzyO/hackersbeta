<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hackers Cup Random Hacker Generator</title>
  <style>
    :root{
      --bg-900:#051226;
      --bg-800:#071731;
      --panel:#071827;
      --muted:#9fb0c6;
      --text:#e6eef7;
      --accent-a:#ffb020;
      --accent-b:#32c5ff;
      --glass:rgba(255,255,255,0.04);
      --glass-2:rgba(255,255,255,0.06);
      --shadow: 0 18px 50px rgba(2,6,23,0.6);
      --radius:18px;
      --ctrl-h:48px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;font-family:Inter,ui-sans-serif,system-ui,Segoe UI,Roboto,"Helvetica Neue",Arial;
      color:var(--text);background:linear-gradient(180deg,var(--bg-900),var(--bg-800));
      -webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;display:flex;align-items:center;justify-content:center;padding:28px;
    }

    .app{width:min(1180px,100%);display:grid;grid-template-columns:1.35fr .85fr;gap:26px}

    .panel{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:var(--radius);padding:22px;border:1px solid var(--glass-2);box-shadow:var(--shadow)}

    /* LEFT HERO */
    .left{display:flex;flex-direction:column;align-items:center;gap:12px;padding:28px}
    h1{margin:0;font-size:clamp(24px,3.4vw,36px);letter-spacing:0.02em;font-weight:800}
    .subtitle{margin:0;color:var(--muted);font-size:14px}

    .wheel-wrap{position:relative;width:min(64vw,560px);height:min(64vw,560px);display:grid;place-items:center}
    .pointer{position:absolute;top:-8px;left:50%;transform:translateX(-50%);width:0;height:0;border-left:20px solid transparent;border-right:20px solid transparent;border-top:44px solid var(--accent-a);filter:drop-shadow(0 8px 18px rgba(0,0,0,0.6));z-index:6}

    canvas{width:100%;height:100%;border-radius:999px;background:radial-gradient(1200px circle at 20% 20%, rgba(50,197,255,0.06), transparent 12%), rgba(255,255,255,0.02);box-shadow:inset 0 -16px 40px rgba(0,0,0,0.5),0 24px 60px rgba(0,0,0,0.6)}

    .center-badge{position:absolute;z-index:4;width:124px;height:124px;border-radius:999px;background:linear-gradient(135deg,var(--accent-a),#f59e0b);display:grid;place-items:center;color:#061426;font-weight:900;font-size:14px;box-shadow:0 10px 30px rgba(0,0,0,0.5)}

    .controls{display:flex;gap:12px;align-items:center;justify-content:center;margin-top:12px}
    button{border:0;cursor:pointer;border-radius:999px;padding:12px 18px;font-weight:800}
    .spin-btn{background:linear-gradient(90deg,var(--accent-a),var(--accent-b));color:#071426;padding:14px 20px;min-width:170px;box-shadow:0 8px 30px rgba(43,20,6,0.15)}
    .spin-btn:active{transform:translateY(2px)}
    .secondary-btn{background:transparent;border:1px solid var(--glass);color:var(--text);padding:10px 14px}

    /* RIGHT COLUMN */
    .right{display:flex;flex-direction:column;gap:14px}
    .field,.result,.stats,.list-box{background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:12px;padding:14px;border:1px solid var(--glass)}
    .label{font-size:12px;color:var(--muted);letter-spacing:0.09em;text-transform:uppercase;margin-bottom:8px;font-weight:700}
    input[type="text"]{width:100%;border-radius:10px;border:1px solid var(--glass);background:rgba(5,10,18,0.4);color:var(--text);padding:10px 12px}

    .result h2{margin:0;font-size:12px;color:var(--muted);text-transform:uppercase}
    .winner{font-size:34px;margin:6px 0 0;font-weight:900}
    .winner-sub{color:var(--muted);margin:8px 0 0}

    .stats{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .stat{padding:12px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));border:1px solid var(--glass)}
    .stat .k{font-size:11px;color:var(--muted);text-transform:uppercase;font-weight:700}
    .stat .v{font-size:20px;font-weight:900}

    .player-list{list-style:none;margin:0;padding:0;display:grid;gap:8px;max-height:45vh;overflow:auto}
    .player-list li{display:flex;justify-content:space-between;padding:10px;border-radius:10px;background:linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));border:1px solid var(--glass);}    
    .player-list li strong{color:var(--accent-b)}

    .footnote{font-size:12px;color:var(--muted)}

    /* Small screens */
    @media (max-width:980px){
      .app{grid-template-columns:1fr;gap:12px}
      .wheel-wrap{width:min(86vw,420px);height:min(86vw,420px)}
      .center-badge{width:96px;height:96px}
      .controls{flex-direction:column}
      .controls button{width:100%}
    }
  </style>
</head>
<body>
  <div class="app">
    <section class="panel left">
      <h1>Hackers Cup Spin Wheel</h1>
      <p class="subtitle">Random Hacker Generator • Spin to draw a Hackers Cup number</p>

      <div class="wheel-wrap">
        <div class="pointer"></div>
        <canvas id="wheel" width="1400" height="1400"></canvas>
        <div class="center-badge">HACKERS<br>CUP</div>
      </div>

      <div class="controls">
        <button class="spin-btn" id="spinBtn">Spin Wheel</button>
        <button class="secondary-btn" id="spinSearchBtn">Spin Filtered</button>
        <button class="secondary-btn" id="resetBtn">Reset</button>
      </div>
    </section>

    <aside class="panel right">
      <div class="field">
        <label class="label" for="searchInput">Filter players</label>
        <input id="searchInput" type="text" placeholder="Type a name or number..." />
      </div>

      <div class="result">
        <h2>Selected Hacker</h2>
        <p class="winner" id="winnerName">Ready to spin</p>
        <p class="winner-sub" id="winnerMeta">273 loaded</p>
      </div>

      <div class="stats">
        <div class="stat">
          <div class="k">Total loaded</div>
          <div class="v" id="totalCount">0</div>
        </div>
        <div class="stat">
          <div class="k">Filtered pool</div>
          <div class="v" id="filteredCount">0</div>
        </div>
      </div>

      <div class="list-box">
        <div class="list-head">
          <h3>Hackers</h3>
          <span class="footnote">Showing live filtered list</span>
        </div>
        <ul class="player-list" id="playerList"></ul>
      </div>

      
    </aside>
  </div>

  <script>
