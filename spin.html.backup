    const canvas = document.getElementById('wheel');
    const ctx = canvas.getContext('2d');
    const spinBtn = document.getElementById('spinBtn');
    const spinSearchBtn = document.getElementById('spinSearchBtn');
    const resetBtn = document.getElementById('resetBtn');
    const searchInput = document.getElementById('searchInput');
    const spinSound = new Audio('assets/audio/spin.mp3');
    spinSound.preload = 'auto';
    const winnerName = document.getElementById('winnerName');
    const winnerMeta = document.getElementById('winnerMeta');
    const totalCount = document.getElementById('totalCount');
    const filteredCount = document.getElementById('filteredCount');
    const playerList = document.getElementById('playerList');
    const wheelWrap = document.querySelector('.wheel-wrap');

    let rotation = 0;
    let spinning = false;
    let filteredPlayers = [...players];
    let wheelCacheCanvas = null;
    let wheelCacheKey = '';

    function normalizeText(text) {
      return text
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function getPalette(i) {
      const palettes = [
        ['#0ea5e9', '#0369a1'],
        ['#f59e0b', '#b45309'],
        ['#22c55e', '#15803d'],
        ['#a855f7', '#7e22ce'],
        ['#ef4444', '#b91c1c'],
        ['#14b8a6', '#0f766e'],
        ['#eab308', '#a16207'],
        ['#3b82f6', '#1d4ed8']
      ];
      return palettes[i % palettes.length];
    }

    function renderList() {
      playerList.innerHTML = filteredPlayers
        .slice(0, 273)
        .map(p => `<li><strong>#${p.no}</strong><span>${p.name}</span></li>`)
        .join('');
    }

    function getWheelCacheKey(pool) {
      if (!pool.length) return 'empty';
      return `${pool.length}:${pool[0].no}:${pool[pool.length - 1].no}:${canvas.width}x${canvas.height}`;
    }

    function buildWheelCache(pool = filteredPlayers) {
      const w = canvas.width;
      const h = canvas.height;
      const cx = w / 2;
      const cy = h / 2;
      const radius = Math.min(w, h) / 2 - 18;

      const cached = document.createElement('canvas');
      cached.width = w;
      cached.height = h;
      const cctx = cached.getContext('2d');

      if (!pool.length) {
        cctx.save();
        cctx.translate(cx, cy);
        cctx.beginPath();
        cctx.arc(0, 0, radius, 0, Math.PI * 2);
        cctx.fillStyle = '#334155';
        cctx.fill();
        cctx.fillStyle = '#ffffff';
        cctx.font = 'bold 54px Inter, Arial';
        cctx.textAlign = 'center';
        cctx.textBaseline = 'middle';
        cctx.fillText('No matches', 0, 0);
        cctx.restore();
        return cached;
      }

      const sliceAngle = (Math.PI * 2) / pool.length;

      cctx.save();
      cctx.translate(cx, cy);

      for (let i = 0; i < pool.length; i++) {
        const start = i * sliceAngle - Math.PI / 2;
        const end = start + sliceAngle;
        const [c1, c2] = getPalette(i);

        const grad = cctx.createLinearGradient(
          Math.cos(start) * radius,
          Math.sin(start) * radius,
          Math.cos(end) * radius,
          Math.sin(end) * radius
        );
        grad.addColorStop(0, c1);
        grad.addColorStop(1, c2);

        cctx.beginPath();
        cctx.moveTo(0, 0);
        cctx.arc(0, 0, radius, start, end);
        cctx.closePath();
        cctx.fillStyle = grad;
        cctx.fill();

        cctx.lineWidth = 2;
        cctx.strokeStyle = 'rgba(255,255,255,0.22)';
        cctx.stroke();

        const mid = start + sliceAngle / 2;
        cctx.save();
        cctx.rotate(mid);
        cctx.textAlign = 'right';
        cctx.fillStyle = '#ffffff';

        const showFullName = pool.length <= 120;
        const text = showFullName ? `#${pool[i].no} ${pool[i].name}` : `#${pool[i].no}`;
        const fontSize = Math.max(16, Math.min(30, 240 / Math.sqrt(pool.length)));
        cctx.font = `700 ${fontSize}px Inter, Arial`;
        cctx.translate(radius - 26, 0);
        cctx.rotate(Math.PI / 2);

        const maxWidth = radius * 0.72;
        let output = text;
        while (cctx.measureText(output).width > maxWidth && output.length > 12) {
          output = output.slice(0, -2);
        }
        if (output !== text) output = output.trim() + '...';

        cctx.fillText(output, 0, 0);
        cctx.restore();
      }

      cctx.beginPath();
      cctx.arc(0, 0, radius * 0.12, 0, Math.PI * 2);
      cctx.fillStyle = 'rgba(255,255,255,0.9)';
      cctx.fill();
      cctx.restore();

      return cached;
    }

    function ensureWheelCache(pool = filteredPlayers) {
      const key = getWheelCacheKey(pool);
      if (key !== wheelCacheKey || !wheelCacheCanvas) {
        wheelCacheCanvas = buildWheelCache(pool);
        wheelCacheKey = key;
      }
    }

    function drawWheel(pool = filteredPlayers) {
      const w = canvas.width;
      const h = canvas.height;
      const cx = w / 2;
      const cy = h / 2;
      ctx.clearRect(0, 0, w, h);
      ensureWheelCache(pool);

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.drawImage(wheelCacheCanvas, -w / 2, -h / 2, w, h);
      ctx.restore();
    }

    function sizeCanvasToContainer() {
      const rect = wheelWrap.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const displaySize = Math.max(220, Math.floor(Math.min(rect.width, rect.height)));
      const internalSize = Math.floor(displaySize * dpr);

      canvas.style.width = `${displaySize}px`;
      canvas.style.height = `${displaySize}px`;

      if (canvas.width !== internalSize || canvas.height !== internalSize) {
        canvas.width = internalSize;
        canvas.height = internalSize;
        wheelCacheKey = '';
      }
    }

    function getFilteredPlayers() {
      const q = normalizeText(searchInput.value || '');
      if (!q) return [...players];
      return players.filter(p => {
        return normalizeText(p.name).includes(q) || String(p.no).includes(q);
      });
    }

    function updateFiltered() {
      filteredPlayers = getFilteredPlayers();
      filteredCount.textContent = filteredPlayers.length;
      renderList();
      wheelCacheKey = '';
      drawWheel(filteredPlayers);
    }

    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }

    function spin(pool) {
      if (spinning || !pool.length) return;
      spinning = true;
      spinBtn.disabled = true;
      spinSearchBtn.disabled = true;
      resetBtn.disabled = true;

      const targetIndex = Math.floor(Math.random() * pool.length);
      const sliceAngle = (Math.PI * 2) / pool.length;

      // Pointer is at 12 o'clock. Need selected slice midpoint to end there.
      const targetMid = targetIndex * sliceAngle + sliceAngle / 2;
      const current = rotation % (Math.PI * 2);
      const extraSpins = (Math.PI * 2) * (5 + Math.random() * 2.5);
      const desired = (-targetMid) - current;
      const finalRotation = rotation + extraSpins + desired;
      const startRotation = rotation;
      const duration = 5200;
      const start = performance.now();

      function animate(now) {
        const elapsed = now - start;
        const t = Math.min(1, elapsed / duration);
        rotation = startRotation + (finalRotation - startRotation) * easeOutCubic(t);
        drawWheel(pool);

        if (t < 1) {
          requestAnimationFrame(animate);
        } else {
          rotation = finalRotation;
          drawWheel(pool);
          const winner = pool[targetIndex];
          winnerName.textContent = winner.name;
          winnerMeta.textContent = `Hacker #${winner.no}`;
          spinning = false;
          spinBtn.disabled = false;
          spinSearchBtn.disabled = false;
          resetBtn.disabled = false;
        }
      }

      requestAnimationFrame(animate);
    }

    function playSpinSound() {
      spinSound.muted = false;
      spinSound.currentTime = 0;
      spinSound.play().catch(() => {
        // Ignore autoplay restrictions or transient playback errors.
      });
    }

    spinBtn.addEventListener('click', () => {
      playSpinSound();
      spin(players);
    });
    spinSearchBtn.addEventListener('click', () => {
      playSpinSound();
      spin(filteredPlayers);
    });

    resetBtn.addEventListener('click', () => {
      rotation = 0;
      winnerName.textContent = 'Ready to spin';
      winnerMeta.textContent = `${players.length} loaded`;
      searchInput.value = '';
      filteredPlayers = [...players];
      updateFiltered();
    });

    searchInput.addEventListener('input', updateFiltered);

    window.addEventListener('resize', () => {
      sizeCanvasToContainer();
      drawWheel(filteredPlayers);
    });

    totalCount.textContent = players.length;
    sizeCanvasToContainer();
    updateFiltered();
  </script>
</body>
</html>