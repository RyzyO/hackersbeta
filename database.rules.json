{
  "rules": {
    "notifications": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "root.child('admins').child(auth.uid).val() === true || auth.uid === $uid"
      }
    },
    "fcmTokens": {
      "$uid": {
        ".read": "root.child('admins').child(auth.uid).val() === true",
        ".write": "auth.uid === $uid"
      }
    },
    "admins": {
      ".read": "auth !== null",
      ".write": false
    },
    "users": {
      ".read": true,
      ".write": "root.child('admins').child(auth.uid).val() === true",
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        "handicap": {
          ".validate": "newData.isNumber()"
        },
        "scoringSession": {
          ".validate": "newData.isObject()"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}

